# ASSESSMENT CONTEXT BUILDER
# Completely different from Agent 2's route_context()
# Agent 2: per-account transaction evidence
# Agent 3: systemic patterns, regulatory framework, market correlation
# ══════════════════════════════════════════════════════════════════════════════

def _build_assessment_context(
    agent2_context: dict,
    systemic_df: pd.DataFrame,
    typology_df: pd.DataFrame,
    market_df: pd.DataFrame,
    entity_df: pd.DataFrame,
    corridors_df: pd.DataFrame,
) -> str:
    lines = []

    # Section 1: Agent 2 Handoff
    lines.append("=" * 72)
    lines.append("SECTION 1: AGENT 2 INVESTIGATION FINDINGS (handoff from investigator)")
    lines.append("=" * 72)
    if agent2_context:
        acct = agent2_context.get("selected_account", "Unknown")
        lines.append(f"Primary account investigated: {acct}")
        lines.append(f"Total flagged accounts: {agent2_context.get('flagged_count', 'N/A')}")
        lines.append(f"\nAgent 1 detection summary:\n{agent2_context.get('agent1_summary', 'Not available')}")
        lines.append("\nInvestigator conversation (last 3 turns):")
        for turn in agent2_context.get("full_history", [])[-3:]:
            lines.append(f"  Q: {turn['question']}")
            lines.append(f"  A: {turn['answer'][:300]}...")
    else:
        lines.append("No Agent 2 context. Running standalone batch assessment.")

    # Section 2: Portfolio Risk
    lines.append("\n" + "=" * 72)
    lines.append("SECTION 2: PORTFOLIO RISK EXPOSURE")
    lines.append("=" * 72)
    if not systemic_df.empty:
        r = systemic_df.iloc[0]
        total_flagged  = int(r.get("total_flagged_accounts", 0))
        confirmed      = int(r.get("confirmed_laundering_accounts", 0))
        sar_eligible   = int(r.get("sar_eligible_accounts", 0))
        multi          = int(r.get("multi_indicator_accounts", 0))
        exposure       = float(r.get("total_exposure_usd", 0))
        avg_score      = float(r.get("avg_priority_score", 0))
        max_score      = float(r.get("max_priority_score", 0))
        total_cc       = int(r.get("total_cross_currency_txns", 0))
        total_hvw      = int(r.get("total_high_value_wires", 0))
        lines.append(f"Total flagged accounts     : {total_flagged:,}")
        lines.append(f"Confirmed laundering       : {confirmed:,}")
        lines.append(f"SAR-eligible accounts      : {sar_eligible:,}")
        lines.append(f"Multi-indicator accounts   : {multi:,}")
        lines.append(f"Total exposure             : ${exposure:,.0f} USD")
        lines.append(f"Priority score avg / max   : {avg_score:.1f} / {max_score:.1f}")
        lines.append(f"Cross-currency transactions: {total_cc:,}")
        lines.append(f"High-value wire transfers  : {total_hvw:,}")
        if total_flagged > 0:
            lines.append(f"Confirmation rate          : {confirmed/total_flagged*100:.1f}%")
            lines.append(f"SAR eligibility rate       : {sar_eligible/total_flagged*100:.1f}%")

    # Section 3: AML Typology
    lines.append("\n" + "=" * 72)
    lines.append("SECTION 3: AML TYPOLOGY CONFIRMATION")
    lines.append("=" * 72)
    if not typology_df.empty:
        for _, r in typology_df.iterrows():
            lines.append(
                f"  {str(r.get('payment_format','?')):16s} | "
                f"typology={str(r.get('aml_typology','?')):12s} | "
                f"txns={int(r.get('total_transactions',0)):>8,} | "
                f"laundering={int(r.get('laundering_count',0)):>6,} | "
                f"rate={float(r.get('laundering_rate_pct',0)):.4f}%"
            )

    # Section 4: Market-Laundering Correlation
    lines.append("\n" + "=" * 72)
    lines.append("SECTION 4: MARKET STRESS CORRELATION (IBM AML unique capability)")
    lines.append("=" * 72)
    if not market_df.empty:
        stress    = market_df[market_df["is_market_stress_day"] == True]
        non_stress = market_df[market_df["is_market_stress_day"] == False]
        avg_i_s  = float(stress["laundering_intensity_vs_10d_avg"].mean()) if not stress.empty else 0
        avg_i_ns = float(non_stress["laundering_intensity_vs_10d_avg"].mean()) if not non_stress.empty else 0
        avg_l_s  = float(stress["laundering_count"].mean()) if not stress.empty else 0
        avg_l_ns = float(non_stress["laundering_count"].mean()) if not non_stress.empty else 0
        lines.append(f"  Stress days (JPM & GS both negative): {len(stress)}/{len(market_df)}")
        lines.append(f"  Avg laundering intensity — stress days   : {avg_i_s:.3f}x")
        lines.append(f"  Avg laundering intensity — calm days     : {avg_i_ns:.3f}x")
        lines.append(f"  Avg laundering count    — stress days    : {avg_l_s:.1f}")
        lines.append(f"  Avg laundering count    — calm days      : {avg_l_ns:.1f}")
        if avg_i_s > avg_i_ns and avg_i_ns > 0:
            uplift = ((avg_i_s / avg_i_ns) - 1) * 100
            lines.append(f"  Laundering uplift on stress days         : +{uplift:.1f}%")
        lines.append("\n  Day-by-day:")
        for _, r in market_df.iterrows():
            flag = " *** STRESS ***" if r.get("is_market_stress_day") else ""
            lines.append(
                f"    {r.get('transaction_date','?')} | "
                f"launder={int(r.get('laundering_count',0)):>4} | "
                f"intensity={float(r.get('laundering_intensity_vs_10d_avg',0)):.2f}x | "
                f"jpm={float(r.get('jpm_daily_return_pct',0)):+.2f}% | "
                f"gs={float(r.get('gs_daily_return_pct',0)):+.2f}%{flag}"
            )

    # Section 5: Entity Risk
    lines.append("\n" + "=" * 72)
    lines.append("SECTION 5: ENTITY TYPE RISK DISTRIBUTION")
    lines.append("=" * 72)
    if not entity_df.empty:
        type_map = {0: "Corporation", 1: "Partnership", 2: "Sole Proprietorship", -1: "Unknown"}
        for _, r in entity_df.iterrows():
            enc = int(r.get("entity_type_encoded", -1))
            lines.append(
                f"  {type_map.get(enc,'Unknown'):22s} | "
                f"entities={int(r.get('entity_count',0)):>6,} | "
                f"avg_rate={float(r.get('avg_laundering_rate',0)):.4f}% | "
                f"avg_banks={float(r.get('avg_banks_involved',0)):.1f} | "
                f"vol=${float(r.get('total_volume',0)):>14,.0f}"
            )

    # Section 6: Hot Corridors
    lines.append("\n" + "=" * 72)
    lines.append("SECTION 6: HIGH-RISK BANK CORRIDORS (cross-institutional view)")
    lines.append("=" * 72)
    if not corridors_df.empty:
        for i, (_, r) in enumerate(corridors_df.iterrows(), 1):
            lines.append(
                f"  #{i:02d} Bank {int(r.get('from_bank',0)):>6} → "
                f"Bank {int(r.get('to_bank',0)):>6} | "
                f"rate={float(r.get('laundering_rate_pct',0)):.4f}% | "
                f"txns={int(r.get('transaction_count',0)):>6,} | "
                f"vol=${float(r.get('total_volume_usd',0)):>12,.0f}"
            )
    else:
        lines.append("  Hot corridor data unavailable.")

    return "\n".join(lines)


