    r = systemic_df.iloc[0]
    cols = st.columns(5)
    metrics = [
        ("Flagged Accounts",     f"{int(r.get('total_flagged_accounts',0)):,}",
         "in investigation queue",    "#93C5FD"),
        ("Confirmed Laundering", f"{int(r.get('confirmed_laundering_accounts',0)):,}",
         "ground-truth positive",     "#F87171"),
        ("SAR Eligible",         f"{int(r.get('sar_eligible_accounts',0)):,}",
         "meet filing threshold",     "#FBBF24"),
        ("Total Exposure",       f"${float(r.get('total_exposure_usd',0))/1e6:.1f}M",
