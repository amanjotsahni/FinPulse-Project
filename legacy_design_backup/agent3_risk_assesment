# PARSE DEEPSEEK R1 RESPONSE
# R1 produces <think>...</think> + final answer — we display BOTH
# ══════════════════════════════════════════════════════════════════════════════

def _parse_r1_response(raw_text: str) -> tuple:
    think_match    = re.search(r'<think>(.*?)</think>', raw_text, re.DOTALL)
    thinking_chain = think_match.group(1).strip() if think_match else ""
    final_report   = re.sub(r'<think>.*?</think>', '', raw_text, flags=re.DOTALL).strip()
    return thinking_chain, final_report


def _extract_risk_level(report_text: str) -> str:
    for level in ["CRITICAL", "HIGH", "MEDIUM", "LOW"]:
        if level in report_text.upper():
            return level
    return "UNKNOWN"


