@st.cache_data(ttl=300, show_spinner=False)
def _fetch_hottest_corridors() -> pd.DataFrame:
    """Top 10 most dangerous bank-to-bank corridors. IBM AML unique capability."""
    from config import DATABRICKS_SCHEMA
    try:
        return _query(f"""
            SELECT
                from_bank, to_bank,
                transaction_count,
                total_volume_usd,
                laundering_count,
                laundering_rate_pct,
                cross_currency_count
            FROM {DATABRICKS_SCHEMA}.cross_bank_flow
            WHERE transaction_count > 500
            ORDER BY laundering_rate_pct DESC
            LIMIT 10
        """)
    except Exception:
        return pd.DataFrame()


