@st.cache_data(ttl=300, show_spinner=False)
def _fetch_entity_risk_distribution() -> pd.DataFrame:
    """Entity type risk — Corporation vs Partnership vs Sole Proprietorship."""
    from config import DATABRICKS_SCHEMA
    try:
        return _query(f"""
            SELECT
                entity_type_encoded,
                COUNT(*)                            AS entity_count,
                SUM(laundering_count)               AS total_laundering,
                ROUND(AVG(laundering_rate_pct), 4)  AS avg_laundering_rate,
                SUM(total_volume_usd)               AS total_volume,
                ROUND(AVG(banks_involved), 2)       AS avg_banks_involved
            FROM {DATABRICKS_SCHEMA}.entity_laundering_profile
            GROUP BY entity_type_encoded
            ORDER BY avg_laundering_rate DESC
        """)
    except Exception:
