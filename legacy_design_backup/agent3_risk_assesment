@st.cache_data(ttl=300, show_spinner=False)
def _fetch_systemic_risk_summary() -> pd.DataFrame:
    """
    Portfolio-level risk summary across ALL flagged accounts.
    Agent 2 looked at one account. Agent 3 looks at ALL of them together.
    """
    from config import DATABRICKS_SCHEMA
    return _query(f"""
        SELECT
            COUNT(*)                                    AS total_flagged_accounts,
            SUM(CASE WHEN is_laundering = 1
                THEN 1 ELSE 0 END)                      AS confirmed_laundering_accounts,
            SUM(CASE WHEN flag_confirmed_fraud = 1
                THEN 1 ELSE 0 END)                      AS sar_eligible_accounts,
            SUM(CASE WHEN flag_multi_risk = 1
                THEN 1 ELSE 0 END)                      AS multi_indicator_accounts,
            ROUND(AVG(priority_score), 2)               AS avg_priority_score,
            ROUND(MAX(priority_score), 2)               AS max_priority_score,
            SUM(total_amount)                           AS total_exposure_usd,
            SUM(cross_currency_count)                   AS total_cross_currency_txns,
            SUM(high_value_wire_count)                  AS total_high_value_wires
        FROM {DATABRICKS_SCHEMA}.investigation_queue
    """)


@st.cache_data(ttl=300, show_spinner=False)
def _fetch_typology_breakdown() -> pd.DataFrame:
    """
    AML typology distribution from fraud_rate_by_type.
    Agent 3 uses this to formally confirm typology in the risk classification.
    """
    from config import DATABRICKS_SCHEMA
    return _query(f"""
        SELECT
            payment_format,
            total_transactions,
            laundering_count,
            laundering_rate_pct,
            CASE
                WHEN payment_format = 'Wire Transfer' THEN 'Integration'
                WHEN payment_format = 'ACH'           THEN 'Layering'
                WHEN payment_format = 'Cheque'        THEN 'Structuring'
                WHEN payment_format = 'Reinvestment'  THEN 'Layering'
                WHEN payment_format = 'Credit Card'   THEN 'Placement'
                ELSE 'Unknown'
            END                                         AS aml_typology
        FROM {DATABRICKS_SCHEMA}.fraud_rate_by_type
        ORDER BY laundering_rate_pct DESC
    """)


@st.cache_data(ttl=300, show_spinner=False)
def _fetch_market_stress_correlation() -> pd.DataFrame:
    """
    The crown jewel — laundering intensity vs market stress correlation.
    UNIQUE to IBM AML dataset. Does laundering spike during banking sector stress?
    """
    from config import DATABRICKS_SCHEMA
    return _query(f"""
        SELECT
            transaction_date,
            total_transactions,
            total_volume_usd,
            laundering_count,
            laundering_rate_pct,
