def _market_correlation_chart(market_df: pd.DataFrame):
    """Laundering intensity vs market stress days — the IBM AML unique chart."""
    if market_df.empty:
        return
    try:
        import plotly.graph_objects as go
        from plotly.subplots import make_subplots
    except ImportError:
        st.info("Install plotly: pip install plotly")
        st.dataframe(
            market_df[[
                "transaction_date", "laundering_count",
                "laundering_intensity_vs_10d_avg",
                "jpm_daily_return_pct", "gs_daily_return_pct",
                "is_market_stress_day"
            ]].set_index("transaction_date"),
            use_container_width=True,
        )
        return

    dates      = market_df["transaction_date"].astype(str).tolist()
    intensity  = market_df["laundering_intensity_vs_10d_avg"].fillna(1.0).tolist()
    jpm        = market_df["jpm_daily_return_pct"].fillna(0).tolist()
    gs         = market_df["gs_daily_return_pct"].fillna(0).tolist()
    stress     = market_df["is_market_stress_day"].tolist()

    fig = make_subplots(
        rows=2, cols=1,
        subplot_titles=(
            "Laundering Intensity vs 10-Day Average (red = banking stress day)",
            "Banking Sector Performance — JPM & GS Daily Return %",
        ),
        vertical_spacing=0.18,
        shared_xaxes=True,
    )

    bar_colors = ["#F87171" if s else "#60A5FA" for s in stress]
    fig.add_trace(go.Bar(
        x=dates, y=intensity,
        name="Laundering Intensity",
        marker_color=bar_colors, opacity=0.85,
    ), row=1, col=1)
    fig.add_hline(
        y=1.0, line_dash="dot",
        line_color="rgba(255,255,255,0.3)",
        annotation_text="Baseline 1.0x",
        row=1, col=1,
    )
    fig.add_trace(go.Scatter(
        x=dates, y=jpm,
        name="JPM Daily Return %",
        line=dict(color="#60A5FA", width=2),
        mode="lines+markers",
    ), row=2, col=1)
    fig.add_trace(go.Scatter(
        x=dates, y=gs,
        name="GS Daily Return %",
        line=dict(color="#A78BFA", width=2, dash="dot"),
        mode="lines+markers",
    ), row=2, col=1)
    fig.add_hline(y=0, line_dash="dash", line_color="rgba(255,255,255,0.2)", row=2, col=1)

    fig.update_layout(
        plot_bgcolor="#0F1E35", paper_bgcolor="#0F1E35",
        font=dict(color="#7E9BB8", size=11),
        legend=dict(bgcolor="rgba(15,30,53,0.8)",
                    bordercolor="rgba(96,165,250,0.2)", borderwidth=1),
        margin=dict(l=40, r=20, t=50, b=40),
        height=480,
    )
    fig.update_xaxes(gridcolor="rgba(96,165,250,0.05)", showgrid=True)
    fig.update_yaxes(gridcolor="rgba(96,165,250,0.05)", showgrid=True)

    st.plotly_chart(fig, use_container_width=True)
    st.caption(
        "🔴 Red bars = market stress days (JPM & GS both negative return). "
        "Bars above 1.0x = laundering above 10-day rolling average. "
        "Overlap confirms coordinated capital flight hypothesis."
    )


