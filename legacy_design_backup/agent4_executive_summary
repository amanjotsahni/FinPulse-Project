def _detection_timeline_html(agent1_results: list, agent3_output: dict) -> str:
    """Visual investigation timeline — shows the 4-agent process as a story."""
    today     = datetime.now()
    events = [
        (today - timedelta(hours=3), "🔍 Agent 1 Detection",
         "AI scanned 5M+ transactions using Isolation Forest",
         "#60A5FA"),
        (today - timedelta(hours=2), "🕵️ Agent 2 Investigation",
         "Compliance analyst investigated highest-priority account",
         "#A78BFA"),
        (today - timedelta(hours=1), "⚖️ Agent 3 Risk Assessment",
         f"DeepSeek R1 classified systemic risk: "
         f"{agent3_output.get('risk_level','UNKNOWN') if agent3_output else 'Pending'}",
         "#FBBF24"),
        (today,                      "📋 Agent 4 Executive Report",
         "Plain-English narrative generated for decision makers",
         "#34D399"),
    ]

    items = ""
    for i, (ts, title, desc, color) in enumerate(events):
        connector = (
            f'<div style="width:2px;height:24px;background:rgba(96,165,250,0.15);'
            f'margin-left:11px;"></div>'
            if i < len(events) - 1 else ""
        )
        items += f"""
        <div style="display:flex;gap:14px;align-items:flex-start;">
            <div style="flex-shrink:0;width:24px;height:24px;border-radius:50%;
                        background:{color};display:flex;align-items:center;
                        justify-content:center;font-size:11px;margin-top:2px;">
            </div>
            <div style="flex:1;padding-bottom:4px;">
                <div style="font-size:11px;font-weight:700;color:#FFFFFF;">{title}</div>
                <div style="font-size:10px;color:#7E9BB8;margin-top:2px;">{desc}</div>
                <div style="font-size:9px;color:#4A6080;margin-top:2px;">
                    {ts.strftime('%H:%M')}</div>
            </div>
        </div>
