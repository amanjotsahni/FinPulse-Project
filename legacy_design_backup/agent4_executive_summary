        f"Agent 1 (Isolation Forest): {len(agent1_results):,} transactions scored" if agent1_results else "Agent 1: Not run",
        f"Agent 2 (Groq Llama 3.3):  Account investigation completed",
        f"Agent 3 (DeepSeek R1):     Risk level = {agent3_output.get('risk_level','N/A')}" if agent3_output else "Agent 3: Not completed",
        f"Agent 4 (Groq Llama 3.3):  Executive narrative generated",
        "",
        "=" * 72,
        "DISCLAIMER",
        "=" * 72,
        "This report was generated by the FinPulse AI-powered AML Intelligence",
        "Platform using the IBM AML synthetic transaction dataset (NeurIPS 2023).",
        "All findings relate to synthetic data and should not be construed as",
        "findings about real individuals, banks, or transactions.",
        "=" * 72,
    ]
    return "\n".join(lines)


# ══════════════════════════════════════════════════════════════════════════════
# MAIN ENTRY POINT
# ══════════════════════════════════════════════════════════════════════════════

def run_executive_narrative(
    agent1_results: list,
    agent2_context: dict = None,
    agent3_output: dict  = None,
):
    """
    Main Agent 4 render function.
    Called from app.py with outputs from all three prior agents.
    """
    try:
        client = _get_groq_client()
    except Exception as e:
        st.error(f"Groq client initialisation failed: {e}")
        return

    # Fallback — try session state if not passed directly
    if not agent2_context:
        agent2_context = st.session_state.get("agent2_context")
    if not agent3_output:
        agent3_output = st.session_state.get("agent3_output")

    risk_level = agent3_output.get("risk_level", "UNKNOWN") if agent3_output else "UNKNOWN"

    # ── Page header ───────────────────────────────────────────────────────────
    st.markdown(
        """<div style="margin-bottom:24px;">
            <div style="font-size:9px;letter-spacing:0.2em;text-transform:uppercase;
                        color:#4A6080;font-weight:700;margin-bottom:4px;">
                Agent 4 · Groq Llama 3.3 · Executive Narrative</div>
            <div style="font-size:22px;font-weight:800;color:#FFFFFF;">
                Board-Ready Report Generator</div>
            <div style="font-size:13px;color:#7E9BB8;margin-top:6px;line-height:1.6;">
                Translates all AI findings into plain-English narratives for
                boards, regulators, and press. No jargon. Decisions-first format.
            </div></div>""",
        unsafe_allow_html=True,
    )

    # ── Pipeline summary ──────────────────────────────────────────────────────
    st.markdown(
        _pipeline_summary_html(agent1_results, agent2_context, agent3_output),
        unsafe_allow_html=True,
    )

    # ── Agent 3 status check ──────────────────────────────────────────────────
    if not agent3_output:
        st.warning(
            "⚠️ Agent 3 risk assessment not found. "
            "Run Agent 3 first for the richest executive narrative. "
            "Proceeding with available data."
        )
    else:
        st.success(
            f"✅ All agents complete. Risk level: **{risk_level}**. "
            f"Ready to generate {risk_level}-tier executive narrative."
        )

    st.markdown("<div style='height:20px'></div>", unsafe_allow_html=True)

    # ── Audience selector ─────────────────────────────────────────────────────
    st.markdown(
        '<div style="font-size:9px;letter-spacing:0.14em;text-transform:uppercase;'
        'color:#4A6080;margin-bottom:12px;font-weight:700;">Select Report Audience</div>',
        unsafe_allow_html=True,
    )

    audience_options = ["Board of Directors", "Regulatory Filing", "Press Statement"]
    audience_icons   = ["🏛️", "⚖️", "📰"]
    audience_descs   = [
        "C-suite & board risk committee\nFocus: exposure, decisions, approvals",
        "FinCEN / regulatory examiners\nFocus: SAR, legal framework, timeline",
        "Media & public communications\nFocus: transparency, reassurance",
    ]
    audience_colors  = ["96,165,250", "251,191,36", "52,211,153"]

    # Use radio for actual selection, cards for visual
    selected_audience = st.radio(
        "audience",
        options=audience_options,
        format_func=lambda x: f"{audience_icons[audience_options.index(x)]} {x}",
        horizontal=True,
        label_visibility="collapsed",
    )

    # Visual cards below the radio
    cols = st.columns(3)
    for i, (option, icon, desc, color) in enumerate(
        zip(audience_options, audience_icons, audience_descs, audience_colors)
    ):
        with cols[i]:
            st.markdown(
                _audience_card_html(
                    option, icon, desc,
                    selected=option == selected_audience,
                    color=color,
                ),
                unsafe_allow_html=True,
            )

    st.markdown("<div style='height:20px'></div>", unsafe_allow_html=True)

    # ── Investigation timeline + action items (side by side) ──────────────────
    left_col, right_col = st.columns([1, 1])
    with left_col:
        st.markdown(
            _detection_timeline_html(agent1_results, agent3_output),
            unsafe_allow_html=True,
        )
    with right_col:
        st.markdown(
            _action_items_html(risk_level),
            unsafe_allow_html=True,
        )

    st.markdown("<div style='height:24px'></div>", unsafe_allow_html=True)

    # ── Generate narrative ────────────────────────────────────────────────────
    st.markdown(
        f'<div style="font-size:9px;letter-spacing:0.14em;text-transform:uppercase;'
        f'color:#4A6080;margin-bottom:12px;font-weight:700;">'
        f'Executive Narrative — {selected_audience}</div>',
        unsafe_allow_html=True,
    )

    cache_key = f"agent4_narrative_{selected_audience}_{risk_level}"

    col_gen, col_clear = st.columns([2, 6])
    with col_gen:
        generate_clicked = st.button(
            "📋 Generate Narrative",
            type="primary",
            use_container_width=True,
        )
    with col_clear:
        if st.button("🗑 Clear Narrative", use_container_width=True):
            if cache_key in st.session_state:
                del st.session_state[cache_key]
            st.rerun()

    if generate_clicked or cache_key in st.session_state:
        if generate_clicked or cache_key not in st.session_state:
            briefing = _build_narrative_briefing(
                agent1_results=agent1_results,
                agent2_context=agent2_context,
                agent3_output=agent3_output,
                audience=selected_audience,
            )

            system_prompt = _SYSTEM_PROMPTS.get(
                selected_audience,
                _SYSTEM_PROMPTS["Board of Directors"],
            )

            with st.spinner(f"Writing {selected_audience} narrative..."):
                try:
                    stream = client.chat.completions.create(
                        model="llama-3.3-70b-versatile",
                        messages=[
                            {"role": "system", "content": system_prompt},
                            {"role": "user",   "content": briefing},
                        ],
                        temperature=0.4,   # slightly higher for natural writing
                        max_tokens=1200,
                        stream=True,
                    )

                    # Document header card
                    st.markdown(
                        _narrative_card_html(selected_audience, "", risk_level),
                        unsafe_allow_html=True,
                    )

                    # Stream the narrative
                    stream_box    = st.empty()
                    full_narrative = ""
                    for chunk in stream:
                        delta = chunk.choices[0].delta.content or ""
                        if delta:
                            full_narrative += delta
                            stream_box.markdown(full_narrative)

                    st.session_state[cache_key] = {
                        "narrative":  full_narrative,
                        "audience":   selected_audience,
                        "timestamp":  datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
                        "risk_level": risk_level,
                    }

                except Exception as e:
                    st.error(f"Groq error: {e}")
                    return

        else:
            # Render from cache
            cached = st.session_state[cache_key]
            st.markdown(
                _narrative_card_html(
                    cached["audience"], "", cached["risk_level"]
                ),
                unsafe_allow_html=True,
            )
            st.markdown(cached["narrative"])

        # ── Download button ───────────────────────────────────────────────────
        cached    = st.session_state[cache_key]
        narrative = cached["narrative"]

        st.markdown("<div style='height:16px'></div>", unsafe_allow_html=True)

        download_text = _generate_download_text(
            audience=selected_audience,
            narrative=narrative,
            agent1_results=agent1_results,
            agent3_output=agent3_output,
        )

        col_dl, col_meta = st.columns([2, 6])
        with col_dl:
            filename = (
                f"finpulse_{selected_audience.lower().replace(' ','_')}_"
                f"{datetime.now().strftime('%Y%m%d_%H%M')}.txt"
            )
            st.download_button(
                label="⬇️ Download Report",
                data=download_text,
                file_name=filename,
                mime="text/plain",
                use_container_width=True,
            )
        with col_meta:
            st.markdown(
                f'<div style="font-size:10px;color:#4A6080;padding-top:8px;">'
                f'Generated: {cached["timestamp"]} · '
                f'Model: Groq Llama 3.3 70B Versatile · '
                f'Audience: {selected_audience}'
                f'</div>',
                unsafe_allow_html=True,
            )

        # Save to disk
        output_dir  = _PROJECT_ROOT / "data" / "ai_reports"
        output_dir.mkdir(parents=True, exist_ok=True)
        report_path = output_dir / filename.replace(".txt", ".json")
        with open(report_path, "w") as f:
            json.dump({
                "audience":       selected_audience,
                "narrative":      narrative,
                "risk_level":     risk_level,
                "timestamp":      cached["timestamp"],
                "agent1_count":   len(agent1_results),
                "agent2_account": agent2_context.get("selected_account") if agent2_context else None,
                "agent3_report":  agent3_output.get("final_report","") if agent3_output else "",
            }, f, indent=2)

        st.info(f"Report also saved to `{report_path.name}`")

    else:
        # Idle state
        st.markdown(
            f"""<div style="background:rgba(15,30,53,0.6);border:1px solid rgba(96,165,250,0.12);
                            border-radius:8px;padding:28px;text-align:center;">
                <div style="font-size:28px;margin-bottom:12px;">📋</div>
                <div style="font-size:14px;font-weight:700;color:#FFFFFF;margin-bottom:6px;">
                    Ready to generate {selected_audience} narrative</div>
                <div style="font-size:12px;color:#7E9BB8;line-height:1.7;">
                    Click <strong>Generate Narrative</strong> to produce a<br>
                    plain-English executive report for <strong>{selected_audience}</strong>.<br>
                    All four agent outputs will be synthesised into one coherent story.
                </div></div>""",
            unsafe_allow_html=True,
        )