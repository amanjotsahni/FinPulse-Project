# CONTEXT ASSEMBLY — Distils all prior agent outputs into narrative briefing
# ══════════════════════════════════════════════════════════════════════════════

def _build_narrative_briefing(
    agent1_results: list,
    agent2_context: dict,
    agent3_output: dict,
    audience: str,
) -> str:
    """
    Builds a plain-English briefing document for the LLM to convert into
    executive narrative. Deliberately strips technical jargon — by the time
    it reaches Agent 4, the analysis is done. Now we need the story.
    """
    lines = []

    # ── Intelligence Summary ──────────────────────────────────────────────────
    lines.append("INTELLIGENCE SUMMARY FOR EXECUTIVE NARRATIVE")
    lines.append("=" * 60)
    lines.append(f"Report date: {datetime.now().strftime('%B %d, %Y')}")
    lines.append(f"Target audience: {audience}")
    lines.append(f"Dataset: IBM AML HI-Small — 5,078,316 financial transactions")
    lines.append(f"Period covered: September 1-10, 2022 (10 banking days)")
    lines.append("")

    # ── Agent 1 Summary ───────────────────────────────────────────────────────
    lines.append("WHAT THE AI DETECTION ENGINE FOUND (Agent 1)")
    lines.append("-" * 40)
    if agent1_results:
        high  = [r for r in agent1_results if r.get("confidence_tier") == "HIGH"]
        med   = [r for r in agent1_results if r.get("confidence_tier") == "MEDIUM"]
        fraud = [r for r in agent1_results if r.get("is_fraud") == 1]
        scores = [r.get("anomaly_score", 0) for r in agent1_results]
        top3   = sorted(agent1_results, key=lambda r: r.get("anomaly_score", 0), reverse=True)[:3]

        lines.append(f"The AI scanned {len(agent1_results):,} transactions.")
        lines.append(f"Serious concern (HIGH tier): {len(high)} accounts")
        lines.append(f"Worth reviewing (MEDIUM tier): {len(med)} accounts")
        lines.append(f"Ground-truth confirmed laundering: {len(fraud)} accounts")
        lines.append(f"AI score range: {min(scores):.0f} to {max(scores):.0f} out of 100")
        lines.append(f"Top 3 most suspicious:")
        for r in top3:
            lines.append(
                f"  - Account {r.get('account_id','?')}: score {r.get('anomaly_score',0):.0f}/100"
                f" ({r.get('confidence_tier','?')} risk)"
                f" at {r.get('entity_name','unknown entity')}"
            )
        # Typology counts
        r1 = sum(r.get("rule1_flag", 0) for r in agent1_results)
        r2 = sum(r.get("rule2_flag", 0) for r in agent1_results)
        r3 = sum(r.get("rule3_flag", 0) for r in agent1_results)
        lines.append(f"Large wire transfers (>$100K) flagged: {r1}")
        lines.append(f"Currency-switching transactions flagged: {r2}")
        lines.append(f"High-risk bank routing flagged: {r3}")
    else:
        lines.append("Agent 1 results not available.")
    lines.append("")

    # ── Agent 2 Summary ───────────────────────────────────────────────────────
    lines.append("WHAT THE INVESTIGATOR FOUND (Agent 2)")
    lines.append("-" * 40)
    if agent2_context:
        acct  = agent2_context.get("selected_account", "Unknown")
        turns = len(agent2_context.get("full_history", []))
        lines.append(f"Primary account investigated: {acct}")
        lines.append(f"Investigation depth: {turns} rounds of questioning")
        lines.append("Key findings from the investigation:")
        for turn in agent2_context.get("full_history", [])[-4:]:
            lines.append(f"  Question: {turn['question']}")
            lines.append(f"  Finding: {turn['answer'][:200].strip()}...")
            lines.append("")
    else:
        lines.append("No specific account investigation was conducted.")
        lines.append("Proceeding with portfolio-level narrative.")
    lines.append("")

    # ── Agent 3 Summary ───────────────────────────────────────────────────────
    lines.append("WHAT THE RISK ASSESSMENT CONCLUDED (Agent 3)")
    lines.append("-" * 40)
    if agent3_output:
        risk_level   = agent3_output.get("risk_level", "UNKNOWN")
        final_report = agent3_output.get("final_report", "")
        lines.append(f"OVERALL RISK CLASSIFICATION: {risk_level}")
        lines.append(f"Assessed by: DeepSeek R1 chain-of-thought reasoning model")
        lines.append(f"Assessment timestamp: {agent3_output.get('timestamp','N/A')}")
        lines.append("")
        lines.append("Risk assessment report (summarise this for your audience):")
        # Pass first 1500 chars of the report — enough for narrative context
        lines.append(final_report[:1500] if final_report else "Not available")
    else:
        lines.append("Agent 3 risk assessment not yet completed.")
        lines.append("Run Agent 3 before generating the executive narrative.")
    lines.append("")

    # ── The Market Correlation Story ──────────────────────────────────────────
    lines.append("THE UNIQUE MARKET CORRELATION FINDING")
    lines.append("-" * 40)
    lines.append("IBM AML is the only public dataset that gives a complete view")
    lines.append("across ALL banks — real banks can only see their own transactions.")
    lines.append("This allowed FinPulse to answer: when banking stocks fell,")
    lines.append("did money laundering activity increase?")
    lines.append("September 2022 saw JPM and GS stock decline on several days.")
    lines.append("The analysis checked whether laundering spiked on those same days.")
    lines.append("This finding has direct implications for how financial crime")
    lines.append("relates to market volatility and potential coordinated capital flight.")
    lines.append("")

    # ── Audience Instructions ─────────────────────────────────────────────────
    lines.append("NARRATIVE INSTRUCTIONS")
    lines.append("-" * 40)
    audience_instructions = {
        "Board of Directors": (
            "Write a 1-page board briefing. Assume the audience knows nothing about AML technology. "
            "Focus on: financial exposure, reputational risk, what actions management has taken, "
            "and what the board needs to decide or approve. Use dollar amounts prominently. "
            "End with 3 board-level questions that need to be addressed."
        ),
        "Regulatory Filing": (
            "Write a formal regulatory disclosure narrative. Tone is precise, factual, and complete. "
            "Reference BSA/AML framework, FinCEN reporting requirements, and FATF guidelines. "
            "Include: detection methodology, findings, classification rationale, actions taken, "
            "and timeline. This will be read by compliance examiners. "
            "Include a formal SAR recommendation with justification."
        ),
        "Press Statement": (
            "Write a 3-paragraph press statement. Tone is measured, transparent, and reassuring. "
            "Paragraph 1: What was detected and when. Paragraph 2: What action was taken. "
            "Paragraph 3: What this means for customers and the institution's commitment to compliance. "
            "No technical jargon. No admission of failure. Emphasise proactive detection."
        ),
    }
    lines.append(audience_instructions.get(audience, "Write a professional executive summary."))

    return "\n".join(lines)


