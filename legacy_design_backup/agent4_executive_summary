    return f"""
    <div style="background:#0F1E35;border:1px solid rgba(96,165,250,0.12);
                border-radius:8px;padding:20px 22px;">
        <div style="font-size:9px;color:#4A6080;text-transform:uppercase;
                    letter-spacing:0.14em;font-weight:700;margin-bottom:16px;">
            Investigation Timeline</div>
        {items}
    </div>"""


